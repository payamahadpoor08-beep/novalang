// The f64 JIT track with mixed int/float arithmetic, int-literal comparisons,
// integer for-range loops in float bodies, and % / ** lowered natively.

fn horner(x) {
  acc = 0.0
  for i in 0..50 { acc = acc * x + i * 0.5 + 1 }
  acc
}

fn wrap_angle(a) {
  r = a % 6.283185307179586
  if r < 0 { r + 6.283185307179586 } else { r }
}

fn decay(x) {
  steps = 0.0
  while x > 1 {
    x = x * 0.75 - 0.125
    steps = steps + 1
  }
  steps
}

fn compound(p, r) {
  p * (1 + r) ** 12
}

fn main() {
  t = 0.0
  k = 0.0
  while k < 300.0 {
    t = t + horner(1.001) * 0.000001
    k = k + 1
  }
  print(t)
  print(wrap_angle(10.0))
  print(wrap_angle(0.0 - 10.0))
  print(decay(1000000.5))
  print(compound(100.0, 0.01))
}
