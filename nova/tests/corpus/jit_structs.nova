// JIT struct kernels: a local struct whose fields are ints lowers to arena
// slots (field -> compile-time slot index). Aliases share the handle exactly
// like the interpreter's Rc struct. Escaping structs keep the function off the
// JIT. Output must be byte-identical across interp and all VM/JIT modes.

struct Point { x: Int, y: Int }
struct Acc { lo: Int, hi: Int, n: Int }

fn walk(n) {
    let p = Point { x: 0, y: 0 }
    let mut i = 0
    while i < n {
        p.x = p.x + 2
        p.y = p.y + p.x
        i = i + 1
    }
    p.x + p.y
}

fn minmax(n) {
    let a = Acc { lo: 999999, hi: 0 - 999999, n: 0 }
    let mut i = 1
    while i <= n {
        let v = (i * 37) % 101
        if v < a.lo { a.lo = v }
        if v > a.hi { a.hi = v }
        a.n = a.n + 1
        i = i + 1
    }
    a.lo * 1000000 + a.hi * 1000 + a.n
}

fn alias_shared(k) {
    let p = Point { x: 1, y: 2 }
    let q = p
    q.x = k
    p.x + p.y + q.y
}

fn escapes() {
    let p = Point { x: 7, y: 8 }
    p
}

fn main() {
    print(walk(50000))
    print(minmax(1000))
    print(alias_shared(40))
    let e = escapes()
    print(e.x * 10 + e.y)
}
