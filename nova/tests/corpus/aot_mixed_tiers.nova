fn fib(n) { if n < 2 { n } else { fib(n-1) + fib(n-2) } }
fn favg(a, b) { (a + b) / 2.0 }
fn describe(xs) {
  let s = "["
  let first = true
  for x in xs {
    if first { first = false } else { s = s + "|" }
    s = s + x
  }
  s + "]"
}
fn main() {
  print(fib(20))
  print(favg(3.0, 4.5))
  print(describe(["a", "b", "c"]))
  print(f"fib(10)={fib(10)} avg={favg(1.0, 2.0)}")
}
