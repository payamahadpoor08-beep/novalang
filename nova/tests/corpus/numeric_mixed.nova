// Mixed int/float kernels on the unified numeric JIT track: integer loop
// counters and accumulators driving float math, returning both int and float.
// Every tier must print byte-identically to `nova run`.

fn mandel(w, h, maxi) {
  total = 0
  for py in 0..h {
    for px in 0..w {
      x0 = to_float(px) / to_float(w) * 3.5 - 2.5
      y0 = to_float(py) / to_float(h) * 2.0 - 1.0
      x = 0.0
      y = 0.0
      it = 0
      while x*x + y*y <= 4.0 && it < maxi {
        xt = x*x - y*y + x0
        y = 2.0*x*y + y0
        x = xt
        it = it + 1
      }
      if it == maxi { total = total + 1 }
    }
  }
  total
}

fn harmonic(n) {
  s = 0.0
  for i in 1..n { s = s + 1.0 / to_float(i) }
  s
}

fn mixed_round(n) {
  acc = 0
  for i in 0..n { acc = acc + to_int(to_float(i) * 2.5 + 0.5) }
  acc
}

fn main() {
  print(mandel(80, 80, 100))
  print(harmonic(50))
  print(mixed_round(20))
}
