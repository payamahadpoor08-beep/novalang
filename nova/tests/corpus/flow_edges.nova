// Flow-boundary and scoping edge cases where the VM must match the
// tree-walker exactly: expression blocks consume every Flow (return yields
// the block value, break/continue/throw fall through to the tail), statement
// blocks share the function's flat scope, and writes inside an expression
// block shadow instead of mutating.

fn break_returns() { break 9 }

fn main() {
  // bindings made inside if/for bodies persist (flat function scope)
  if 1 < 2 { y = 41 }
  print(y + 1)
  for i in 0..3 {}
  print(i)

  // expression block: writes shadow the outer binding
  x = 1
  z = { x = 2; x + 10 }
  print(x)
  print(z)

  // return inside an expression block yields the block's value, skips the tail
  a = { return 5; 3 }
  print(a)

  // throw inside an expression block is swallowed; the tail still runs
  b = { throw "e"; 3 }
  print(b)

  // break inside an expression block does NOT break the enclosing loop
  n = 0
  while n < 3 {
    c = { break; 99 }
    print(c)
    n = n + 1
  }
  print("done " + str(n))

  // break with a value: inside a loop the value is discarded; at function
  // level it acts like a return
  k = 0
  while true {
    k = k + 1
    if k == 3 { break k * 10 }
  }
  print(k)
  print(break_returns())
}
