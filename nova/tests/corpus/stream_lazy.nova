// Lazy streams = the generator runtime. A `yield`ing function returns a
// Generator that `for x in ...` pulls one element at a time, so an *infinite*
// producer is fine as long as the consumer stops. A `stream[T]` return-type
// annotation is accepted and documents that intent. Output must be byte-
// identical across interp and all VM/JIT modes.

fn naturals() -> stream[Int] {
    let mut i = 0
    while true {
        yield i
        i = i + 1
    }
}

fn squares_up_to(n) {
    let mut i = 1
    while i <= n {
        yield i * i
        i = i + 1
    }
}

// pull the first `n` values of a (possibly infinite) stream into an array
fn take(g, n) {
    let out = []
    let mut c = 0
    for x in g {
        if c >= n { break }
        push(out, x)
        c = c + 1
    }
    out
}

fn main() {
    print(take(naturals(), 6))          // lazy: naturals() never ends on its own
    print(take(squares_up_to(4), 10))   // finite stream, take more than it has
    let mut total = 0
    for s in squares_up_to(5) { total = total + s }
    print(total)
}
