fn count_primes(n) {
  s = []
  for i in 0..n { push(s, 1) }
  s[0] = 0
  s[1] = 0
  i = 2
  while i * i < n {
    if s[i] == 1 {
      j = i * i
      while j < n { s[j] = 0; j = j + i }
    }
    i = i + 1
  }
  c = 0
  for k in 0..n { c = c + s[k] }
  c
}
fn main() { print(count_primes(2000000)) }
