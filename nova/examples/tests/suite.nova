use math.{sqrt, gcd, pow}

fn factorial(n) {
  if n <= 1 { 1 } else { n * factorial(n - 1) }
}

fn fib(n) {
  if n < 2 { n } else { fib(n - 1) + fib(n - 2) }
}

test "factorial computes correctly" {
  assert_eq(factorial(5), 120)
  assert_eq(factorial(0), 1)
  assert_eq(factorial(1), 1)
}

test "fibonacci sequence" {
  assert_eq(fib(0), 0)
  assert_eq(fib(1), 1)
  assert_eq(fib(10), 55)
}

test "math module works" {
  assert_eq(gcd(48, 36), 12)
  assert_eq(pow(2, 10), 1024.0)
  assert(sqrt(16) == 4.0)
}

test "arrays behave correctly" {
  nums = [5, 2, 8, 1]
  assert_eq(len(nums), 4)
  push(nums, 9)
  assert_eq(len(nums), 5)
  assert_eq(sort(nums), [1, 2, 5, 8, 9])
}

test "this one should FAIL on purpose" {
  assert_eq(1 + 1, 3, "math is broken")
}

test "string operations" {
  assert_eq(upper("hello"), "HELLO")
  assert(contains("nova lang", "lang"))
}
